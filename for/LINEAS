void setup(){
  size(700, 700);
}

void draw(){
  
  int n = 8;
  
  patron(width, height, n);
}

void patron(float w, float h, int n)
{
  float paso = w / (n - 1);
  
  rect(0, 0, w, h);
  
  for(int i = 0; i < n; i++)
  {
    float x = i * paso;
    float y = h;
    

    line(x, y, 0, 0);
    line(x, y, w, 0);
  }
}
